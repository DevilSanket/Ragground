# Ground Up Reels Pipeline — Environment Variables
# ─────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to git!

# ── Gemini API ────────────────────────────────────
# Get your API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── PostgreSQL (optional, only if DB_TYPE=postgres) ──
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=groundup_reels
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password_here

# ── Database backend ─────────────────────────────
# 'sqlite' = local embedded DB (default, recommended for dev/HuggingFace)
# 'postgres' = PostgreSQL with pgvector (for production)
DB_TYPE=sqlite

# ── Instagram (instaloader session) ──────────────
# Run: instaloader --login <your_ig_username>
# This saves a session file. Set the username here.
IG_USERNAME=your_instagram_username_here
